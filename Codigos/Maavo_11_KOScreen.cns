[State 119911991, 1]
type = AssertSpecial
trigger1 = time < 50
flag = nobardisplay
flag2 = nomusic

[State 911, SuperPause]
type = Pause
trigger1 = time = 0
time = 50
movetime = 50
[State 911, SuperPause]
type = Pause
triggerall = time %3 = 0
triggerall = time = [50,120]
trigger1 = enemy, statetype != L
trigger1 = roundstate < 4
trigger1 = root, stateno != 1213
time = 2
movetime = 2
[State 911, SuperPause]
type = Pause
triggerall = time %2 = 0
triggerall = time = [121,160]
trigger1 = enemy, statetype != L
trigger1 = roundstate < 4
trigger1 = root, stateno != 1213
time = 1
movetime = 1
[State 911, 1]
type = Explod
trigger1 = Time = 0
id = 911
