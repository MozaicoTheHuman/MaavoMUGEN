;Standing Strong Punch - Motion Trail
[StateDef 221]
type = S
movetype= A
anim = 221
poweradd = 0
sprpriority = -1

[State xd]
type = AssertSpecial
trigger1 = 1
flag = noshadow

[State a]
type = BindtoRoot
trigger1 = time < 13
time = -1
facing = 1
pos = 20,-25

[State 0, Trans]
type = Trans
trigger1 = 1
trans = add
alpha = 256,256
ignorehitpause = 1
persistent = 1

[State 0, AngleDraw]
type = AngleDraw
trigger1 = time > 0
value = 54
ignorehitpause = 1

[State 0, ChangeState]
type = DestroySelf
trigger1 = animtime = 0

