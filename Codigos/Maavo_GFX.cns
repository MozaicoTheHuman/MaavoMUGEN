;---------------------------------------------------------------------------
;Ve, Ivette! - Ivette Cayendo (FX 1)
[Statedef 99022]
type    = S
movetype= A
physics = N
velset = 0,0
ctrl = 0
anim = 13042
facep2 = 1

[State 0, Trans]
type = Trans
trigger1 = 1
trans = add
ignorehitpause = 1

[State a]
type = BindtoParent
trigger1 = 1
time = -1
facing = 1
pos = 0,0

[State 1100, 3]
type = AngleDraw
Trigger1 = 1
value = -55
ignorehitpause = 1

[State 9902, 3]
type = SprPriority
trigger1 = Time = 0
value = 5

[State 9902, 2]
type = VelAdd
trigger1 = time = 0
x = 6
y = 14

[State 0, VelMul]
type = VelMul
triggerall = pos y < 0
trigger1 = time
x = 1.025
y = 1.025

[State xd]
type = AssertSpecial
trigger1 = 1
flag = noshadow

[State 0, PalFXWiz]
type = PalFX
trigger1 = 1
time = -1
add = 0,-200,0
mul = 213,193,266
sinadd = 40,80,40,3
invertall = 0
color = 255

[state 9902, 3]
type = velset
trigger1 = pos y >=0
x = 0
y = 0
[state 9902, 3]
type = posset
trigger1 = pos y >=0
y = 0

[State 9902, ChangeState]
type = DestroySelf
trigger1 = parent, stateno = 182
triggerall = pos y >=0

[State 9902, 4]
type = DestroySelf
Trigger1 = pos y >=0  ;40
[State 0, DestroySelf when hit]
type = DestroySelf
trigger1 = parent, stateno = 3748
