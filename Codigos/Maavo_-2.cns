trigger1 = (GameWidth/GameHeight) >= 1.7
trigger1 = 0&&(var(17):=0)
trigger2 = var(17) = 2
trigger2 = (GameWidth/GameHeight) < 1.7
trigger2 = 0&&(var(17):=1)
ignorehitpause = 1

