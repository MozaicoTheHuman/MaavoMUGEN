;-----------------------------------------------------------------------------------------------
; Counterhit detection
;-----------------------------------------------------------------------------------------------
[State 0, PlaySnd]
type = PlaySnd
triggerall = numenemy
triggerall = roundstate = 2
triggerall = stateno != [800,899] ;Does not activate during throws.
triggerall = !enemynear,movereversed
triggerall = var(42) = 1
trigger1 = var(21) = 1
trigger2 = numhelper
trigger2 = helper,var(21) = 1
value = s42,1
channel = 12
ignorehitpause = 1
persistent = 0

[State -2, Null];Counter Hit state machine
type = Null
;Checks if opponent is in attack state
trigger1 = numenemy
trigger1 = !enemynear,movereversed
trigger1 = enemy,movetype = A
trigger1 = 0&&(var(42):=1)
;Resets the condition if counter not succesful and succesful
trigger2 = numenemy
trigger2 = (enemy,movetype = I||var(43) >= 1)||(var(43) > 10 && enemy,movetype = H)||((time<=1) && (stateno!=[5000,5199]) && (movetype!=H))
trigger2 = 0&&(var(42):=0)
trigger3 = numenemy
trigger3 = var(22)
trigger3 = 0&&(var(42):=1)
;Counter Hit Succesful
trigger4 = !enemynear,movereversed
trigger4 = var(42) = 1 && movehit
trigger4 = stateno != [190,199]
trigger4 = stateno != [800,899]
trigger4 = 0&&(var(43):=1)
;Counter Hit Timer
trigger5 = var(43) >= 1 ;Counter was succesful
trigger5 = 0&&(var(43):=var(43)+1)
;Counter Hit Reset
trigger6 = var(43) >= 22 && movehit ;Reset if 22 ticks passed and move hit
trigger6 = 0&&(var(43):=0)
trigger7 = p2movetype != H ;Reset if P2 is no longer in gethit state
trigger7 = 0&&(var(43):=0)
trigger8 = movetype = H ;Reset if P1 is getting hit
trigger8 = 0&&(var(43):=0)
ignorehitpause = 1

