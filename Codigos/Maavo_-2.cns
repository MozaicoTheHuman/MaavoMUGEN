trigger2 = (((stateno = 180140 || stateno = 181) || stateno = 140002 || (stateno = 141002 || roundstate>2 && prevstateno = 141002) || stateno = 1410025 || numhelper(911)) && movetype != H)||(enemy,name = "Oliver Andersen" && enemy,stateno = [4301,4399])||((enemy,name = "Greninja_GBVS" || enemy,name = "NoNerfs_GBVS") && ((enemy,stateno = [3010,3019]) && enemy,movetype != H || (matchover && enemy,teammode != simul && (enemy,fvar(2)||enemy,stateno=[180,189]))))||(enemy,name = "Maavo" && ((enemy,stateno = 180140 || enemy,stateno = 181) || enemy,stateno = 140002 || (enemy,stateno = 141002 || roundstate>2 && enemy,prevstateno = 141002) || enemy,stateno = 1410025 || enemy,numhelper(911)) && enemy,movetype != H)																	
