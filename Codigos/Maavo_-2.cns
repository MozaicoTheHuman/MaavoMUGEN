trigger12 = (var(10) = 1 && var(11) > 16)||(var(10) = 2 && var(11) = [12,15])
trigger12 = 0&&(fvar(11):=.15*fvar(12))
;Damage Scaling
trigger13 = (var(10) = 2 && var(11) > 15)||(var(10) = 3 && var(11) > 8)
