trigger16 = life > (lifemax*.6504)
trigger16 = 0&&(fvar(12):=1.025)
trigger17 = life <= (lifemax*.6504)
trigger17 = life > (lifemax*.5308)
trigger17 = 0&&(fvar(12):=1.05)
trigger18 = life <= (lifemax*.5308)
trigger18 = life > (lifemax*.4112)
trigger18 = 0&&(fvar(12):=1.075)
trigger19 = life <= (lifemax*.4112)
trigger19 = life > (lifemax*.2916)
trigger19 = 0&&(fvar(12):=1.01)
trigger20 = life <= (lifemax*.2916)
trigger20 = life > (lifemax*.25)
trigger20 = 0&&(fvar(12):=1.0125)
trigger21 = life <= (lifemax*.25)
trigger21 = 0&&(fvar(12):=1.15)
ignorehitpause = 1

