trigger2 = (enemynear,stateno=[150,155])||(enemynear,movetype=H && enemynear,statetype!=A)||((enemynear,stateno=[5020,5040]) && !(enemynear,hitfall))||(((enemynear,stateno=0)||(enemynear,stateno=52)) && (enemynear,prevstateno=[5000,5040]) && ((enemynear,time<=0)||!(enemynear,ctrl)))||((enemynear,stateno=0) && (enemynear,prevstateno=52) && ((enemynear,time<=0)||!(enemynear,ctrl)))||((enemynear,stateno=40) && (enemynear,time>=1||enemynear,prevstateno=0||enemynear,prevstateno=52))
