;///////////////////////////////////////////////////////////////////////////
; Maavo's common states, everything he needs to exist.
;///////////////////////////////////////////////////////////////////////////


[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, 1]
type = ChangeAnim
triggerall = life > (lifemax*.25)
trigger1 = Anim != 0 && Anim != 5 && Anim != 31005
trigger2 = (Anim = 5 || anim = 31005) && AnimTime = 0 ;Turn anim over
value = 0

[State 0, b]
type = ChangeAnim
triggerall = life <= (lifemax*.25)
trigger1 = Anim != 0 && Anim != 5 && Anim != 31005
trigger2 = (Anim = 5 || anim = 31005) && AnimTime = 0 ;Turn anim over
value = 0

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050

;---------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11

;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 0

[State 11, 1] ;Change from turning animation
type = ChangeAnim
trigger1 = Anim = 6 && AnimTime = 0
value = 11

;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0

;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 0, PowerAdd]
type = PowerAdd
triggerall = !var(8)
trigger1 = p2dist x > 0 && vel x > 0
trigger2 = p2dist x < 0 && vel x < 0
value = 1

[State FootSteps]
type = PlaySnd
trigger1 = AnimElem=5
value = S20,0+random%2
freqmul = 0.9+(random/7333.3)

[State FootSteps]
type = PlaySnd
trigger1 = AnimElem=10
value = S21,0+random%2
freqmul = 0.9+(random/7333.3)

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
trigger1= !ailevel
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 20, 4]
type = ChangeAnim
trigger1= !ailevel
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21

;---------------------------------------------------------------------------
; AI Walk
[Statedef 21]
type    = S
physics = S
sprpriority = 0
anim = 20

[State 0, PowerAdd]
type = PowerAdd
triggerall = !var(8)
trigger1 = p2dist x > 0 && vel x > 0
trigger2 = p2dist x < 0 && vel x < 0
value = 1

[State FootSteps]
type = PlaySnd
trigger1 = AnimElem=5
value = S20,0+random%2
freqmul = 0.9+(random/7333.3)

[State FootSteps]
type = PlaySnd
trigger1 = AnimElem=10
value = S21,0+random%2
freqmul = 0.9+(random/7333.3)

[State 20, 1]
type = VelSet
trigger1 = 1
x = const(velocity.walk.fwd.x)

;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
ctrl = 0
sprpriority = 1
[State 0, FUCK YOU DEFAULT AI]
type = ChangeState
trigger1 = ailevel >= 4
value = 0
ctrl = 1
[State 0, FUCK YOU DEFAULT AI]
type = Changeanim
trigger1 = ailevel <= 4
trigger1 = !time
value = 40
[State 0, PlaySnd]
type = PlaySnd
triggerall = palno != 18 && palno != 9 && palno != 37
trigger1 = Animelem = 1
value = S50,0

[State 0, PlaySnd]
type = PlaySnd
triggerall = palno = 18 || palno = 9
trigger1 = Animelem = 1
value = S1959,2
[State 0]
type = PlaySnd
triggerall = palno = 37
trigger1 = Animelem = 1
value = S1959, 21

[State 40, 2]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 41, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 41, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 41, 4]
type = VelSet
trigger1 = AnimTime = 0
x = cond(sysvar(1)=0, const(velocity.jump.neu.x), cond(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))

[State 40, 1]
type = VarSet
trigger1 = Time = 0
var(4) = 0
[State 40, 1]
type = VarSet
triggerall = Time = 0
trigger1 = command="SJ"
trigger1 = command!="NoSJ"
trigger2 = (prevstateno = [100,101]) || (prevstateno = [105,106])
var(4) = 10

[State 41, 4]
type = VarSet
triggerall = AnimTime = 0
trigger1 = Command = "holdup"
v = 4
value = cond(var(4)>=10,10,0)

[State 40, 4]
type = VarSet
triggerall = sysvar(1) = 0
trigger1 = AnimTime = 0
trigger1 = Command != "holdup"
v = 4
value = 1
[State 40, 4]
type = VarSet
triggerall = sysvar(1) != 0
trigger1 = AnimTime = 0
trigger1 = Command != "holdup"
v = 4
value = cond(var(4)>=10,11,1)

[State 40, 4]
type = VelSet
triggerall = AnimTime = 0
trigger1 = Var(4) = 0
y = const(velocity.jump.y)

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = Var(4) = 1
y = const(velocity.jump.y)/1.5
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = Var(4) = 11
y = const(velocity.jump.y)/1.4

[State 40, 4]
type = VelSet
triggerall = AnimTime = 0
trigger1 = Var(4) = 10 && sysvar(1) = 0
y = const(velocity.jump.y)*1.2
[State 40, 4]
type = VelSet
triggerall = AnimTime = 0
trigger1 = Var(4) = 10 && sysvar(1) != 0
y = const(velocity.jump.y)*1.1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = Var(4) = 1
y = const(velocity.jump.y)/1.5

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = var(4) >= 10 && sysvar(1) > 0
x = const(velocity.runjump.fwd.x)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = var(4) >= 10 && sysvar(1) < 0
x = const(velocity.runjump.back.x)

[State 40, VarSet]
type = VarSet
trigger1 = Time = 0
var(27) = 0
[State 40, VarSet]
type = VarSet
trigger1 = Time = 0
trigger1 = command = "SJ"
trigger1 = command != "NoSJ"
var(27) = 1 
[State 40, VarSet]
type = VarSet
trigger1 = AnimTime = 0
trigger1 = var(4) < 10
var(27) = 0

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; AI Jump Start
[Statedef 41]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1

[State 41, PlaySnd]
type = PlaySnd
trigger1 = Animelem = 1
value = S50,0
[State 41, PlaySnd]
type = PlaySnd
triggerall = palno != 18 && palno != 9
trigger1 = Animelem = 1
value = S50,0
[State 41, PlaySnd]
type = PlaySnd
triggerall = palno = 18 || palno = 9
trigger1 = Animelem = 1
value = S1959,2
[State 41, Jump Normal]
type = VarSet
trigger1 = p2bodydist x = [-9,9]
sysvar(1) = 0
[State 41, Jump Back]
type = VarSet
trigger1 = p2bodydist x < -10
sysvar(1) = -1
[State 41, Jump Forward]
type = VarSet
trigger1 = p2bodydist x > 10
sysvar(1) = 1

[State 41, Velset]
type = VelSet
trigger1 = AnimTime = 0
x = cond(sysvar(1)=0, const(velocity.jump.fwd.x), cond(sysvar(1)=1, cond(prevstateno=101,const(velocity.runjump.fwd.x),const(velocity.jump.fwd.x)), const(velocity.jump.back.x)))
y = cond(p2bodydist y < -30,const(velocity.jump.y),const(velocity.jump.y)/1.5) ;Shorthop code

[State 41, ChangeState]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 1
id = 3232
ignorehitpause = 1
;persistent =

[State 0, PlaySnd]
type = PlaySnd
trigger1 = Animelem = 1
value = S50,0

[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45, 2]
type = ChangeAnim
trigger1 = prevstateno = 190002
value = 190004

[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = cond(sysvar(1)=0, const(velocity.airjump.neu.x), cond(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, AfterImage]
type = AfterImage
trigger1 = var(27) = 1 
trigger1 = time = 0
time = 40
TimeGap  = 1
FrameGap = 2
length = 5
palbright = 40,0,0
palcontrast = 220,0,0
palpostbright = 0,0,0
trans = add
paladd = 120,0,0
palmul = .65,.65,.65

[State 0, PlaySnd]
type = PlaySnd
trigger1 = var(27) = 1 
trigger1 = time = 0
value = S50,2

[State 0, PowerAdd]
type = PowerAdd
triggerall = !var(8)
trigger1 = p2dist x > 0 && vel x > 0
trigger2 = p2dist x < 0 && vel x < 0
value = 1

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = cond((vel x)=0||(var(4)=1||var(4)=11), 41, cond((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > -2
trigger1 = SelfAnimExist(anim + 3)
persistent = 0
value = Anim + 3

