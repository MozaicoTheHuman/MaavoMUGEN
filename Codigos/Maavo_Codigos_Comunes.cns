; GUARD (start)
[Statedef 120]
type = U    ;Leave state type unchanged
physics = U ;Leave physics unchanged

[State 0, Hi to Lo]
type = StateTypeSet
TriggerAll = StateType = S
triggerall = ailevel
Trigger1 = var(59) = 0 && command = "holddown"
Trigger2 = var(59) != 0 && P2StateType != A && (Random <= var(59)*20 || var(59) > 9)
stateType = C
physics = C

[State 0, Lo to Hi]
type = StateTypeSet
TriggerAll = StateType = C
TriggerAll = ailevel
Trigger1 = var(59) = 0 && command != "holddown"
Trigger2 = var(59) != 0 && P2StateType = A && (Random <= var(59)*20 || var(59) > 9)
stateType = S
physics = S

[State 0, Stop Guarding]
type = ChangeState
value = 140
triggerall = ailevel
trigger1 = var(59) = 0
trigger1 = command != "holdback"
trigger2 = !InGuardDist
trigger3 = var(59) >= 1
trigger3 = var(59) <= 9
trigger3 = P2BodyDist X < 0
trigger3 = Random <= (10 - var(59)) * 40

[State 120, 1]
type = ChangeAnim
trigger1 = Time = 0
value = 120 + (statetype = C) + (statetype = A)*2

[State 120, 2]
type = StateTypeSet
trigger1 = Time = 0 && statetype = S
physics = S

[State 120, 3]
type = StateTypeSet
trigger1 = Time = 0 && statetype = C
physics = C

[State 120, 4]
type = StateTypeSet
trigger1 = Time = 0 && statetype = A
physics = A

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"
statetype = S
physics = S

[State 120, ChangeNotAi]
type = ChangeState
triggerall = !ailevel
trigger1 = AnimTime = 0
value = 130 + (statetype = C) + (statetype = A)*2
[State 120, ChangeAi]
type = ChangeState
triggerall = ailevel
trigger1 = AnimTime = 0
value = cond((enemy,statetype=C),131,130)
[State 120, Stop Guarding]
type = ChangeState
triggerall = !ailevel
trigger1 = command != "holdback"
trigger2 = !inguarddist
value = 140

