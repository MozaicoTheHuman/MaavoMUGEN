#=====================================================================================================================================================================================================================================================
# SIMUL CAMERA
#=====================================================================================================================================================================================================================================================
[StateDef 1821; type: S; anim: 616; sprpriority: 25;]

if time >= 16 && time <= 120 {
    fvar(0) := 1.0 + 0.1 * (1.0 - ((time-16)/104.0)) * (1.0 - ((time-16)/104.0));
    fvar(1) := -60.0 * (1.0 - ((time-16)/104.0)) * (1.0 - ((time-16)/104.0));
}

if time >= 121 && time <= 154 {
    fvar(0) := 1.0;
}

if time >= 155 && time <= 167 {
    fvar(0) := 1.0 + 0.3 * ((time-155)/12.0)*((time-155)/12.0)*((time-155)/12.0);
    fvar(1) := -35.0 * ((time-155)/12.0)*((time-155)/12.0)*((time-155)/12.0);
}

if time >= 168 {
    fvar(0) := 1.3;
    fvar(1) := -35.0;
}

ignoreHitPause if time >= 16 && time <= 247 {
    zoom{scale: fvar(0); pos: 0, fvar(1);}
}

ignoreHitPause if time >= 248 {
    zoom{scale: fvar(0); pos: cos(time*0.15)*0.6 + 0, sin(time*0.1)*0.4 + fvar(1);}
}

