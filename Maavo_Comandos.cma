[Statedef -1]

;COOL FUCKIN AI STARTS HERE---------------------------------------------------------------------------
[State -1, Null]
type = Null
;Combo condition var(1): reset then check
trigger1 = 1
trigger1 = 0&&(var(1):=0)
trigger2 = (ctrl || (stateno = [100,109]) || stateno = 1022 || (stateno = [116,117]))||(((stateno = [200,299]) || (stateno = [400,499]) || (stateno = [600,699])) && movecontact)
trigger2 = 0&&(var(1):=1)
;Combo condition var(2): reset then check
trigger3 = 1
trigger3 = 0&&(var(2):=0)
trigger4 = (statetype = A && ctrl)||((((stateno = [500,520]) && anim = 1091) || (stateno = 2002 && anim = 2009) || (stateno = [2210,2212])) && movecontact)
trigger4 = 0&&(var(2):=1)
;AI Lock
trigger5 = roundstate = 2 && ctrl
trigger5 = 0&&(var(58):=1)
trigger6 = roundstate != 2
trigger6 = 0&&(var(58):=0)
;GURT var(53)
trigger7 = anim = 5120 || roundstate != 2
trigger7 = 0&&(var(53):=12)
trigger8 = var(53) > 0 && anim != 5120 && roundstate = 2
trigger8 = 0&&(var(53):=var(53)-1)

[State -1, Null]
type = Null
;AI conchetumare
trigger1 = 1
trigger1 = 0&&(var(30):=(prevstateno = [19000,19999]) || (prevstateno = [190000,199999]) || prevstateno = 3000 || prevstateno = 17000 || prevstateno = 1210 || prevstateno = 611 || prevstateno = 1212 || prevstateno = 1213 || prevstateno = 1214 || prevstateno = 141002 || prevstateno = 1410025 || prevstateno = 14100251 || prevstateno = 14100285 || prevstateno = 2200 || (prevstateno = [2210,2220]))
;AI Probability
trigger2 = aiLevel && enemyNear,aiLevel > 0
trigger2 = 0&&(var(59):=ceil(200 * cond(life < lifemax*0.02, 4.0, cond(life < lifemax*0.10, 2.5, cond(life < lifemax*0.25, 1.8, cond(life < lifemax*0.50, 1.3, 1.0))))))
trigger3 = aiLevel && enemyNear,aiLevel = 0
trigger3 = 0&&(var(59):=cond(aiLevel=1,3,cond(aiLevel=2,10,cond(aiLevel=3,20,cond(aiLevel=4,35,cond(aiLevel=5,55,cond(aiLevel=6,85,cond(aiLevel=7,90,cond(aiLevel=8,105,0)))))))))
;Store Enemy PosX then Calc Enemy TrVelX 
trigger4 = aiLevel
trigger4 = gameTime % 2 = 0
trigger4 = 0&&(var(47):=ceil(enemynear,pos x))
trigger5 = aiLevel
trigger5 = gameTime % 2 = 1
trigger5 = 0&&(var(48):=ceil(cond(abs(var(47)) - abs(enemynear,pos x) = 0, enemynear,vel x, abs(var(47)) - abs(enemynear,pos x))))
;Calc CC HitTime then Reset CC when no target
trigger6 = numtarget > 0
trigger6 = 0&&(var(49):=ceil(cond(!enemynear,hitFall, target,getHitVar(hittime), target,getHitVar(fall.recovertime))))
trigger7 = numtarget = 0
trigger7 = 0&&(var(49):=0)
;Calc HitFall
trigger8 = 1
trigger8 = 0&&(var(37):=(enemynear,hitFall) || (var(49) > 8))
;Calc Grounded
trigger9 = 1
trigger9 = 0&&(var(51):=(enemynear,statetype = S) || (enemynear,statetype = C))
;Guard Counter: increment, decay, reset, reset on throw
trigger10 = roundstate = 2 && enemynear,moveguarded
trigger10 = 0&&(var(28):=var(28)+3)
trigger11 = roundstate = 2 && gameTime % 8 = 0 && var(28) > 0
trigger11 = 0&&(var(28):=var(28)-1)
trigger12 = (roundstate != 2)||(enemynear,statetype = L)
trigger12 = 0&&(var(28):=0)
trigger13 = stateno = 800
trigger13 = 0&&(var(28):=0)
ignorehitpause = 1

;AI Default Shit Disabled
[State -1, AI Default Shit Disabled]
type = AssertSpecial
trigger1 = AILevel
flag = nowalk

;---------------------------------------------------------------------------
[State -1, AI Contextual Recovery]
type = ChangeState
value = 5200
triggerall = aiLevel && roundstate = 2 && alive
triggerall = stateno = 5050 && vel y > 0 && pos y >= 0 && canRecover
trigger1 = p2bodydist x >= 80 && random < 800
trigger2 = enemynear,ctrl = 0 && enemynear,movetype != A && random < 600
trigger3 = enemynear,ailevel > 0 && random < 900

;Guard
[State -1, AI Guard]
type = ChangeState
value = cond(statetype = A, 140, cond(enemynear,hitdefattr = C,NA,SA,HA,NP,SP,HP, 130, 120))
triggerall = aiLevel >= 3 && roundstate = 2 && alive && numenemy
triggerall = stateno != [120,132] 
triggerall = stateno != 700 && stateno != 720
triggerall = enemynear,movetype != H && enemynear(!enemynear,alive),statetype != L
triggerall = inguarddist && enemynear,movetype = A && enemynear,stateno != [631,633]
triggerall = ctrl
trigger1 = (ctrl || (stateno = [21,22]) || stateno = 100 || stateno = 0) && statetype != A && pos y = 0
trigger1 = random < var(59) * cond(life < lifemax*0.5, 140, 90)
trigger2 = ctrl && statetype = A
trigger2 = random < var(59) * cond(life < lifemax*0.5, 140, 90)

[State -1, AI Guard Cancel]
type = ChangeState
value = cond(statetype = A, 50, 0)
triggerall = aiLevel && roundstate = 2 && alive && numenemy
triggerall = stateno = [130,132]
trigger1 = !inguarddist && enemynear,movetype != A

