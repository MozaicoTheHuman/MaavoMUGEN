
[Remap]
x = x
y = y
z = z
a = a
b = b
c = c
s = s

;-| Default Values |-------------------------------------------------------
[Defaults]
command.time = 15
command.buffer.time = 1

;-| Misc. |-------------------------------------------------------

[command]
name = "SJ"
command = ~$D,$U
time = 5
buffer.time = 2
[Command]
name = "NoSJ"
command = ~12$D,$U
time = 5
buffer.time = 2

